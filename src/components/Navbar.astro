---
import type { Lang } from "../i18n/config.i18n";
import { ui } from "../i18n/ui.i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const currentPath = Astro.url.pathname;
const switchLangPath =
  lang === "es"
    ? currentPath.replace("/es", "/en")
    : currentPath.replace("/en", "/es");
---

<nav class="flex justify-between items-center py-6 px-10 bg-white border-b">
  <div class="font-bold text-2xl tracking-tighter">LOGOTIPO</div>

  <div class="flex gap-8 items-center">
    
    <a href={`/${lang}/`} class="hover:text-blue-600 transition"
      >{t["nav.home"]}</a
    >
    <a href={`/${lang}/#about`} class="hover:text-blue-600 transition"
      >{t["nav.about"]}</a
    >

    <a
      href={switchLangPath}
      class="bg-gray-100 px-3 py-1 rounded text-sm font-medium hover:bg-gray-200 transition"
    >
      {lang === "es" ? "🇺🇸 EN" : "🇲🇽 ES"}
    </a>
  </div>
</nav>
